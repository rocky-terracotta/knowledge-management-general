LITELLM_API_KEY=
LITELLM_BASE_URL=
LITELLM_MODEL=gemini/gemini-3.1-pro
# Optional aliases if your deployment exposes OpenAI-compatible env names instead.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1
ENABLE_LIVE_NEWS_SYNC=true
GITHUB_ACTIONS_TRIGGER_TOKEN=
GITHUB_REPOSITORY=rocky-terracotta/knowledge-management-general
GITHUB_SYNC_WORKFLOW_ID=sync-data.yml
# Leave unset on Vercel so the bundled seed database is copied to writable /tmp.
DATABASE_PATH=./data/knowledge-alerts.sqlite
EMAIL_FROM=
EMAIL_TO=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
RESEND_API_KEY=
RESEND_FROM=news-alerts@example.com
